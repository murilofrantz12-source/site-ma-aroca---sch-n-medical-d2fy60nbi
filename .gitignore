# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
dev-dist
dev-dist-ssr
*.local
.pnpm-store
.pnpm

# pods-manager atomic build operations (rename/restore leftovers).
# AppManager creates these during build (set-aside previous output before
# running pnpm build, restore on failure). Success path cleans them up;
# failure paths may leave orphans. Always ignore them in version control +
# in the sandbox memGit hydration (see ProjectSandbox.hydrate).
*.bak-*
*.legacy-bak-*
*.failed-*
*.tmp

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Evaluation screenshots
screenshot.png
.eslintcache
.oxlintcache

# Environment variables
.env*
!.env

